{
  "manifest_version": 2,
  "name": "LinguaWatch",
  "version": "1.0.0",
  "description": "Learn English or Spanish while watching streaming videos",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "activeTab",
    "storage",
    "https://api.openai.com/",
    "https://www.youtube.com/",
    "https://m.youtube.com/",
    "https://youtube.com/",
    "https://www.netflix.com/",
    "https://netflix.com/",
    "https://www.max.com/",
    "https://max.com/",
    "https://play.hbomax.com/"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "LinguaWatch",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://youtube.com/*",
        "https://www.netflix.com/*",
        "https://netflix.com/*",
        "https://www.max.com/*",
        "https://max.com/*",
        "https://play.hbomax.com/*"
      ],
      "js": ["content-script.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
